# Build output
**/bin/
**/obj/
artifacts/
publish/

# Vendored tool binaries — NOT committed (kept lean). They are fetched operationally
# per the pinned manifests under tools/*/ (gitleaks.version.json, sentrux.version.json,
# gitversion.version.json) and verified by SHA-256. Gates fail closed until vendored.
tools/gitleaks/bin/
tools/sentrux/bin/
tools/gitversion/bin/
# tools/sentrux/grammars/ is intentionally NOT ignored: the sentrux C# grammar has no downloadUrl
# (it cannot be fetched like the executables), so it is vendored in-repo — pinned + SHA-256-verified
# in sentrux.version.json — so the build and the standalone installer stay offline-capable.

# Doti cycle working state (local; the durable proof is the commit)
.doti/cycle-state.json
.doti/gate-proof.json

# Test and coverage output
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml

# NuGet / package output
*.nupkg
*.snupkg
packages/

# IDE and local user state
.vs/
.idea/
*.user
*.suo
*.rsuser

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak

# OS files
.DS_Store
Thumbs.db
desktop.ini

# 008 FR-030: the Sentrux two-try optimization log (local gate telemetry).
.doti/sentrux-optimization-log.json

# 008 FR-014: .doti/templates is materialized from .doti/core/templates (single source); never committed.
.doti/templates/
