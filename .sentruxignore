# Generated-repo template content is packaged input, not scaffold source.
scaffold/templates/

# Local packaging/publish output is a test or release artifact, not source.
artifacts/
publish/

# 008 FR-029/SC-016 — Sentrux measures CODE complexity/architecture, not prose. Docs, Doti prose (command
# templates, rendered skills, agent-context), and payload metadata are out of the source scope (the floor):
*.md
docs/
.doti/
.agents/
.claude/

# Test code is excluded so the structural barometer measures PRODUCTION architecture only. A test fixture
# legitimately carries many test methods per file (a large, well-structured test file is not a production
# "god file"), and test scaffolding is not the production code whose architecture the gate guards. Excluding
# tests gives a true reading of the production sources; their own size/cohesion is governed by review, not the
# structural signal. (scaffold/templates/ test code is already excluded above as packaged template input.)
test/
