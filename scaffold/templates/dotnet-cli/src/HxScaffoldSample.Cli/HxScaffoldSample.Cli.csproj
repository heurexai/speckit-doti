<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>HxScaffoldSample.Cli</RootNamespace>

    <!-- 007 T042 (FR-025): the scaffolded app inherits the distribution rules. It packs as a framework-dependent
         .NET global tool, so `dotnet pack` + `dotnet tool install` produce commands that run WITHOUT this source
         repo — no Velopack stub, and a tool package ships the built assemblies (no source). The app's config.json
         resolves beside the executable (AppConfiguration.LoadRequired(AppContext.BaseDirectory)) and ships in the
         tool via CopyToPublishDirectory="Always". -->
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>HxScaffoldSample</ToolCommandName>
    <PackageId>ACME_COMPANY.HxScaffoldSample</PackageId>
    <Authors>ACME_COMPANY</Authors>
    <Description>HxScaffoldSample — a sample agent-first .NET CLI generated by the Heurex scaffold.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <None Include="HxScaffoldSample.Cli.config.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="Always" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\HxScaffoldSample\HxScaffoldSample.csproj" />
  </ItemGroup>
</Project>
