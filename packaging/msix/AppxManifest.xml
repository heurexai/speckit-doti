<?xml version="1.0" encoding="utf-8"?>
<!-- MSIX package manifest for the Microsoft Store. Identity matches the reserved product
     (Partner Center -> Product identity). The version is stamped by the store-release workflow.
     Logos under Assets/ are the Heurex primary mark (favicon-dark) composited on the navy brand background. -->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 desktop rescap">

  <Identity Name="Heurex.speckit-doti"
            Publisher="CN=44BD9E29-FD96-49A3-87CD-DCD53760D855"
            Version="0.2.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>speckit-doti</DisplayName>
    <PublisherDisplayName>Heurex</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="hx" Executable="hx.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="speckit-doti"
        Description="Agentic .NET spec-driven development starter kit with an enforced, command-backed doti workflow."
        BackgroundColor="#1A1F4D"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <uap3:Extension Category="windows.appExecutionAlias">
          <uap3:AppExecutionAlias>
            <desktop:ExecutionAlias Alias="hx.exe" />
          </uap3:AppExecutionAlias>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
